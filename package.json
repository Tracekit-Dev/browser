{
  "name": "@tracekit/browser",
  "version": "0.1.1",
  "description": "TraceKit Browser SDK - Error capture, breadcrumbs, and distributed tracing for browser applications",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tracekit-Dev/browser"
  },
  "keywords": [
    "tracekit",
    "error-tracking",
    "browser",
    "observability",
    "distributed-tracing",
    "otlp"
  ]
}
